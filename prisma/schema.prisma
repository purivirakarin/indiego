generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  sessionId     String?   @unique
  displayName   String?
  profileImage  String?
  xp            Int       @default(0)
  rank          String    @default("Observer")
  resetToken    String?   @unique
  resetTokenExp DateTime?
  votes         Vote[]
  posts         Post[]
  comments      Comment[]
  createdAt     DateTime  @default(now())
}

model Event {
  id            String   @id @default(uuid())
  title         String
  date          DateTime
  time          String?
  venue         String?
  sourceLink    String?  @unique
  image         String?
  description   String?
  galleryImages String?
  isHosted      Boolean  @default(false)
  genre         String?
  accessibility String?
  isIndiegoPick Boolean  @default(false)
  rsvps         Rsvp[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VoteOption {
  id    String @id @default(uuid())
  title String
  venue String
  image String?
  votes Vote[]
}

model Vote {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  voteOptionId String
  voteOption   VoteOption @relation(fields: [voteOptionId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([userId])
}

model Rsvp {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  name      String
  email     String
  createdAt DateTime @default(now())

  @@unique([email, eventId])
}

model Post {
  id        String    @id @default(uuid())
  title     String
  body      String
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  body      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  proposal  String
  createdAt DateTime @default(now())
}
